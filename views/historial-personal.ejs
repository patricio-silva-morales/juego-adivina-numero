<!DOCTYPE html>
<html lang="es">
<head>
    <%- include("partials/head") %>
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include("partials/navbar") %>

    <main class="container mt-5">
        <h1>Historial personal</h1>
        <% if (mensaje !== "") { %>
            <div class="alert alert-info">
                <%= mensaje %>
            </div>
        <% } %>

        <form action="/historial-personal" method="POST" class="mb-4"
        >
            <div class="mb-3">
                <label for="nombre" class="form-label">Nombre del jugador
                </label>
                <input type="text" id="nombre" name="nombre" class="form-control" required>
            </div>
            <button type="submit" class="btn btn-primary">Buscar</button>
        </form>

        <% if (
            busquedaRealizada &&
            partidasJugador.length > 0
        ) { %>
            <h3>
                Partidas de <%= nombreBuscado %>
            </h3>

            <table class="table table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>Puntaje</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    <% for (
                        const partida of partidasJugador
                    ) { %>
                        <tr>
                            <td><%= partida.puntaje %></td>
                            <td><%= partida.fecha %></td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
            <p><strong>Total de partidas:</strong><%= totalPartidas %></p>
            <p><strong>Puntaje acumulado:</strong><%= puntajeAcumulado %></p>
            <p><strong>Puntaje promedio:</strong><%= promedio.toFixed(2) %></p>
            <form action="/eliminar-jugador" method="POST">
                <input type="hidden" name="nombre" value="<%= nombreBuscado %>">
                <button type="submit" class="btn btn-danger">Eliminar historial del jugador</button>
            </form>
        <% } %>
    </main>

    <%- include("partials/footer") %>
</body>
</html>